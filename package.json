{
  "name": "lazyish",
  "version": "1.1.1",
  "description": "A lightweight, zero-dependency lazy loading micro-library using native browser APIs",
  "main": "dist/lazyish.cjs.js",
  "module": "dist/lazyish.esm.js",
  "browser": "dist/lazyish.iife.js",
  "types": "dist/types/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/lazyish.esm.js",
      "require": "./dist/lazyish.cjs.js",
      "browser": "./dist/lazyish.iife.js",
      "types": "./dist/types/index.d.ts"
    }
  },
  "sideEffects": false,
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "rollup -c",
    "test": "vitest run",
    "lint": "eslint src test",
    "size": "size-limit"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "size-limit": [
    {
      "path": "dist/lazyish.esm.js",
      "limit": "2 KB"
    }
  ],
  "devDependencies": {
    "@eslint/js": "10.0.1",
    "@rollup/plugin-terser": "1.0.0",
    "@rollup/plugin-typescript": "12.3.0",
    "@size-limit/preset-small-lib": "12.1.0",
    "@typescript-eslint/eslint-plugin": "8.59.1",
    "@typescript-eslint/parser": "8.59.1",
    "eslint": "10.2.1",
    "globals": "17.5.0",
    "jsdom": "29.1.0",
    "rollup": "4.60.2",
    "size-limit": "12.1.0",
    "tslib": "2.8.1",
    "typescript": "6.0.3",
    "typescript-eslint": "8.59.1",
    "vite": "8.0.10",
    "vitest": "4.1.5"
  },
  "keywords": [
    "lazy",
    "loading",
    "images",
    "intersection-observer",
    "typescript"
  ],
  "author": "smonist",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/smonist/lazyish"
  }
}
